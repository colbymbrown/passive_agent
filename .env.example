TELEGRAM_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_telegram_chat_id
ICAL_URL_1=https://calendar.google.com/calendar/ical/you%40gmail.com/public/basic.ics

# LLM backend priority list (tries each in order until one succeeds).
# Use a comma-separated list for fallback: LLM_BACKENDS=publicai,claude,ollama
# Legacy single-backend form still supported: LLM_BACKEND=ollama
LLM_BACKENDS=publicai,claude,ollama
LLM_MODEL=mistral

# Ollama (only needed if LLM_BACKEND=ollama)
OLLAMA_URL=http://localhost:11434

# Claude (only needed if LLM_BACKEND=claude)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Public AI (only needed if LLM_BACKEND=publicai)
PUBLICAI_API_KEY=your_publicai_api_key
