TELEGRAM_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Slack (optional) — if set, Slack is added as a chat channel and receives
# push notifications during work hours (Telegram is used outside work hours).
# Use SLACK_CHANNEL_ID for a channel, or SLACK_USER_ID for a private DM.
#   Channel mode scopes: chat:write, channels:history, channels:read
#   DM mode scopes:      chat:write, im:history, im:read, im:write
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_ID=C0123456789   # channel mode — comment out if using DM mode
# SLACK_USER_ID=U0123456789    # DM mode — your Slack member ID (uncomment to use)
# Discord (optional) — if set, Discord is added as a chat channel.
# Bot needs: Read Message History, Send Messages, View Channel permissions.
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CHANNEL_ID=123456789012345678

ICAL_URL_1=https://calendar.google.com/calendar/ical/you%40gmail.com/public/basic.ics

# LLM backend priority list (tries each in order until one succeeds).
# Use a comma-separated list for fallback: LLM_BACKENDS=publicai,claude,ollama
# Legacy single-backend form still supported: LLM_BACKEND=ollama
LLM_BACKENDS=publicai,claude,ollama
LLM_MODEL=mistral

# Ollama (only needed if LLM_BACKEND=ollama)
OLLAMA_URL=http://localhost:11434

# Claude (only needed if LLM_BACKEND=claude)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Public AI (only needed if LLM_BACKEND=publicai)
PUBLICAI_API_KEY=your_publicai_api_key
